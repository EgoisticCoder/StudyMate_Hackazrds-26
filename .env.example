# =========================================================================
# StudyMate AI - Local Environment Variables (Template)
# =========================================================================
# Copy this file to '.env' and fill in your actual credentials.
#
# Expo CLI automatically loads environment variables prefixed with 
# EXPO_PUBLIC_ and makes them accessible in client-side code via 
# process.env.EXPO_PUBLIC_*.
# =========================================================================

# -------------------------------------------------------------------------
# Neo4j AuraDB Configuration (Primary Graph Store)
# -------------------------------------------------------------------------
# Get these credentials from your Neo4j Aura console (https://console.neo4j.io/)
EXPO_PUBLIC_NEO4J_URI=neo4j+s://your-database-id.databases.neo4j.io
EXPO_PUBLIC_NEO4J_USERNAME=neo4j
EXPO_PUBLIC_NEO4J_PASSWORD=your-neo4j-password-here

# -------------------------------------------------------------------------
# Development Mode (Mock Neo4j for testing without database)
# -------------------------------------------------------------------------
# Set to 'true' to bypass Neo4j entirely and use mock data
# Useful for UI development when database is down or not configured
# When enabled, all Neo4j queries return empty results instantly
EXPO_PUBLIC_NEO4J_MOCK_MODE=false

# -------------------------------------------------------------------------
# Sarvam AI API Configuration (Primary LLM & Speech API)
# -------------------------------------------------------------------------
# Get your API key from Sarvam AI Console (https://sarvam.ai/)
# Used for all AI operations: chat (sarvam-105b), STT (Saaras v3), TTS (Bulbul v3), OCR (Doc Digitization)
EXPO_PUBLIC_SARVAM_API_KEY=your_sarvam_api_key_here
SARVAM_API_KEY=your_sarvam_api_key_here

# -------------------------------------------------------------------------
# Tavily Search API Configuration (Web Search / RAG tool)
# -------------------------------------------------------------------------
# Get your API key from Tavily (https://tavily.com/)
# Used for real-time web reference lookups during AI study sessions.
EXPO_PUBLIC_TAVILY_API_KEY=tvly-your_tavily_api_key_here

# -------------------------------------------------------------------------
# API Proxy Base URL (REQUIRED for native production / EAS builds)
# -------------------------------------------------------------------------
# In dev (Expo Go / dev client), the app auto-discovers the Metro packager's
# LAN host to reach `npm run server` on port 3001 — you don't need this set.
# But a standalone native build (EAS build / TestFlight / Play Store) has no
# packager to infer a host from, so without this set explicitly, native
# production builds silently cannot reach the AI/Neo4j proxy at all.
# Set this to your deployed Vercel URL (no trailing slash), e.g.:
EXPO_PUBLIC_PROXY_BASE_URL=https://your-deployment.vercel.app
